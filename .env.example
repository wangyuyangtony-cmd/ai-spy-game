# ============================================================
# AI Spy Game — Environment Configuration
# Copy this file to .env and modify as needed
# ============================================================

# Server port
PORT=3001

# CORS origin — set to your domain in production, or * to allow all
CORS_ORIGIN=*

# JWT secret — MUST change in production!
JWT_SECRET=your-super-secret-key-here

# Mock mode — set to false to use real LLM API
MOCK_MODE=true

# LLM API settings (only needed if MOCK_MODE=false)
# LLM_API_BASE=https://api.openai.com/v1
# LLM_API_KEY=sk-your-api-key-here
# LLM_DEFAULT_MODEL=gpt-3.5-turbo

# Database path (relative to backend directory)
DB_PATH=./data/spy-game.db
