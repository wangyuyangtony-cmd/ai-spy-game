# ============================================================
# AI Spy Game — Environment Configuration
# Copy this file to .env and modify as needed
# ============================================================

# Server port
PORT=3001

# CORS origin
CORS_ORIGIN=*

# JWT secret — MUST change in production!
JWT_SECRET=your-super-secret-key-here

# Mock mode — set to false to use real LLM API
MOCK_MODE=true

# LLM API settings (only needed if MOCK_MODE=false)
# 
# Option 1: SiliconFlow (硅基流动) — recommended for China servers
#   Register at https://cloud.siliconflow.cn to get a free API key
#   Free models: Qwen2.5-7B, GLM-4-9B, DeepSeek-R1-7B, etc.
#
# LLM_API_BASE=https://api.siliconflow.cn/v1
# LLM_API_KEY=sk-your-siliconflow-api-key
# LLM_DEFAULT_MODEL=Qwen/Qwen2.5-7B-Instruct
#
# Option 2: Groq — recommended for overseas servers
# LLM_API_BASE=https://api.groq.com/openai/v1
# LLM_API_KEY=gsk-your-groq-api-key
# LLM_DEFAULT_MODEL=llama-3.3-70b-versatile
#
# Option 3: OpenAI
# LLM_API_BASE=https://api.openai.com/v1
# LLM_API_KEY=sk-your-openai-api-key
# LLM_DEFAULT_MODEL=gpt-3.5-turbo
#
# Option 4: Any OpenAI-compatible API
# LLM_API_BASE=https://your-api-endpoint/v1
# LLM_API_KEY=your-api-key
# LLM_DEFAULT_MODEL=your-model-name

# Database path
DB_PATH=./data/spy-game.db
